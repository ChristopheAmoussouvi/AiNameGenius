# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Google Gemini — logo image generation (https://ai.google.dev/gemini-api/docs/api-key)
GEMINI_API_KEY=
# Optional: override the image model (default: gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# App
APP_BASE_URL=http://localhost:3000

# Trademark — INPI API Gateway (https://api-gateway.inpi.fr)
# Use your data.inpi.fr account credentials
INPI_USERNAME=
INPI_PASSWORD=

# Affiliate — set your IDs after signing up to each program
# Namecheap: https://www.namecheap.com/affiliates/
AFFILIATE_NAMECHEAP_BASE_URL=https://www.namecheap.com/domains/registration/results/
AFFILIATE_NAMECHEAP_ID=

# GoDaddy: https://www.godaddy.com/affiliate-programs
AFFILIATE_GODADDY_ID=

# Hostinger: https://www.hostinger.fr/affilies
AFFILIATE_HOSTINGER_ID=

# Optional: RDAP concurrency (default: 4)
RDAP_CONCURRENCY=4

# Stripe — credit packs (one-time payments)
# Secret key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret: Stripe Dashboard → Developers → Webhooks →
# endpoint https://ainamegenius.com/api/webhooks/stripe (event checkout.session.completed)
STRIPE_WEBHOOK_SECRET=whsec_...
